# --- Database (Neon serverless Postgres + Drizzle) — gates T3/T4/T6 ---
# Pooled connection for application queries.
DATABASE_URL=
# Direct/unpooled connection for migrations (drizzle-kit migrate).
DATABASE_URL_UNPOOLED=

# --- Privy (auth + embedded wallet) — gates T3/T4 ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Resend (lead emails) — gates T6 ---
RESEND_API_KEY=
# Verified sender + fallback contact address shown on 502.
RESEND_FROM=
CONTACT_FALLBACK_EMAIL=

# --- Content / Noticias pipeline — REQUIRED at BUILD ---
# Read access to the fruteroclub/content repo (the Keystatic GitHub reader reads
# posts at build time; ≥5k/hr API). Use a least-privilege token: a fine-grained PAT
# or GitHub App token with Contents:read on fruteroclub/content (a classic PAT with
# `repo` works too). The /noticias build FAILS without it (DEC-7: never silently
# drop pages). NOT needed at runtime — pages are served as static HTML.
GITHUB_TOKEN=

# --- Site ---
# Per-deploy origin. PROD = https://frutero.club (the app only marks pages
# indexable when this EXACTLY equals the production URL). Staging/preview
# (e.g. dev.frutero.club) should set their own origin so they stay noindex and
# emit correct canonicals.
NEXT_PUBLIC_SITE_URL=https://frutero.club
